{
  "dataset": "hotpotqa",
  "split": "validation",
  "sample_name": "smoke",
  "seed": 42,
  "source_data_dir": "hotpotqa_data",
  "output_root": ".benchmark_data/hotpotqa",
  "manifest_copy_path": "benchmarks/hotpotqa/manifests/smoke_seed42.json",
  "target_qa_count": 5,
  "target_passage_count": 20,
  "retrieval": {
    "method": "ppr",
    "top_k": 10,
    "hit_ks": [1, 3, 5, 10]
  },
  "terag_config": {
    "use_llm_for_ner": true,
    "min_concept_freq": 1,
    "top_k": 10,
    "llm_provider": "openai",
    "llm_model": "gpt-5-nano",
    "extraction_cache_dir": ".benchmark_cache/hotpotqa/smoke/extraction",
    "use_semantic_entity_matching": true
  },
  "embedding_model": {
    "provider": "openai",
    "model": "text-embedding-3-small",
    "cache_dir": ".benchmark_cache/hotpotqa/smoke/embeddings"
  },
  "performance": {
    "prewarm_extraction_cache": true,
    "extraction_workers": 4,
    "query_cache_path": ".benchmark_cache/hotpotqa/smoke/query_ner.json"
  },
  "results_dir": "benchmarks/hotpotqa/results",
  "baseline_path": "benchmarks/hotpotqa/baselines/terag_ppr_openai_smoke.json",
  "regression_thresholds": {
    "hit_rate_at_10_abs_drop": 0.03,
    "mrr_abs_drop": 0.03,
    "avg_query_time_multiplier": 1.3,
    "build_time_multiplier": 1.3
  }
}
